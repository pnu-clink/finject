# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- tex directory(including figures and tables)---
stage1/tex/
paper/overleaf_source/**/*.aux
paper/overleaf_source/**/*.bbl
paper/overleaf_source/**/*.blg
paper/overleaf_source/**/*.fdb_latexmk
paper/overleaf_source/**/*.fls
